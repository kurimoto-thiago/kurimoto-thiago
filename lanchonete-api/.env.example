# ── Aplicação ────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── PostgreSQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lanchonete
DB_USER=lanchonete_user
DB_PASSWORD=lanchonete_pass
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_CARDAPIO=300

# ── Rate limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
